{
  "name": "Python 3",
  // Python 3.12 to match CI, ruff target-version, and the docs (a 3.11 container was never tested).
  "image": "mcr.microsoft.com/devcontainers/python:1-3.12-bookworm",
  "customizations": {
    "codespaces": {
      "openFiles": [
        "README.md",
        "app.py"
      ]
    },
    "vscode": {
      "settings": {},
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance"
      ]
    }
  },
  // requirements-dev.txt = app runtime + dbt + pytest/ruff, so a Codespace can run the full checks.
  "updateContentCommand": "pip3 install --user -r requirements-dev.txt && echo '✅ Requirements installed'",
  "postAttachCommand": {
    "server": "streamlit run app.py --server.enableCORS false --server.enableXsrfProtection false"
  },
  "portsAttributes": {
    "8501": {
      "label": "Application",
      "onAutoForward": "openPreview"
    }
  },
  "forwardPorts": [
    8501
  ]
}
