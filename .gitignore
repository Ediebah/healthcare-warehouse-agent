# --- Python env ---
.venv/
__pycache__/
*.pyc

# --- Synthea (regenerable from the seeded command in the README) ---
synthea/synthea-with-dependencies.jar
synthea/output/

# --- DuckDB warehouse file (rebuilt by the loader + `dbt run`) ---
data/*.duckdb
data/*.duckdb.wal
# ...except the slim demo DB, which the deployed Streamlit app needs (the full one is git-ignored)
!data/healthcare_demo.duckdb

# --- dbt build artifacts ---
warehouse/target/
warehouse/dbt_packages/
warehouse/logs/
logs/
# dbt per-user anonymous id — machine-local, not project content
warehouse/.user.yml

# --- local agent / session tooling (not part of the portfolio) ---
.remember/

# --- secrets ---
.env
**/.env

# --- local verification artifacts ---
.playwright-mcp/
/clinical-agent-*.png
agent/eval_history.jsonl

# --- personal learning notes (local only, kept out of the public repo) ---
/RUNBOOK.md
/CONCEPTS.md
/GOVERNANCE.md
/INTERVIEW.md
/LINKEDIN.md

# --- OS / editor ---
.DS_Store
.vscode/
.idea/

# --- coverage artifacts ---
.coverage
htmlcov/

# --- personal / generated documents (never commit to the public repo) ---
*.docx
